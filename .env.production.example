# Valores usados no build de produção (Vite). Configurar como Environment
# Variables no projeto Vercel — não versionar um .env.production real,
# mesmo sendo URLs públicas (removido do commit inicial deste repo por
# convenção, ver .gitignore).
VITE_API_BASE_URL=https://seu-backend.up.railway.app
VITE_APP_PUBLIC_URL=https://seu-frontend.vercel.app

# DSN do projeto Sentry (Settings → Client Keys). Ausente = SDK desativado
# (no-op), não quebra o build. beforeSend/beforeBreadcrumb já filtram PII/PHI
# antes de qualquer envio (ver src/utils/sentry.ts) — mesmo assim, só configure
# depois de revisar a política de dado sensível de paciente.
# VITE_SENTRY_DSN=
