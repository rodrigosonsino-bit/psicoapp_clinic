{
  "name": "psicoapp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace=packages/whatsapp-core",
    "build:core": "npm run build --workspace=packages/whatsapp-core",
    "dev:psychotherapy": "npm run build:core && npm run dev --workspace=apps/psychotherapy",
    "dev:scheduler": "npm run build:core && npm run dev --workspace=apps/scheduler",
    "psychotherapy": "npm run start --workspace=apps/psychotherapy",
    "scheduler": "npm run start --workspace=apps/scheduler"
  }
}
