# ──────────────────────────────────────────────
#  Servidor
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# URL permitida pelo CORS (frontend).
# Em dev use http://localhost:5173.
# Em produção, coloque a URL real do seu frontend (sem barra final).
# Você pode informar múltiplas origens separadas por vírgula.
CORS_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────────
#  Banco de Dados (PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://psychotherapy:psychotherapy@localhost:5432/psychotherapy_db

# ──────────────────────────────────────────────
#  Autenticação JWT
# ──────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua_chave_jwt_super_segura_minimo_32_chars

# ──────────────────────────────────────────────
#  Bypass de Auth (somente desenvolvimento local)
# ──────────────────────────────────────────────
ALLOW_DEFAULT_USER=true
DEFAULT_USER_ID=e3b0c442-98fc-11ee-b9d1-0242ac120002

# ──────────────────────────────────────────────
#  App (URL base do frontend — usada nos links enviados ao paciente)
# ──────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173
APP_NAME=PsicoApp

# ──────────────────────────────────────────────
#  Lembretes Automáticos (node-cron)
# ──────────────────────────────────────────────
# Defina como "false" para desativar o scheduler
ENABLE_REMINDERS=true

# URL opcional para receber os lembretes via webhook (Z-API, Twilio, etc.)
# Se não definido, os lembretes apenas são logados no servidor
# REMINDER_WEBHOOK_URL=https://seuservico.com/webhooks/reminder

# ──────────────────────────────────────────────
#  WhatsApp (Baileys — envio direto de lembretes)
# ──────────────────────────────────────────────
# Defina como "false" para desativar (lembretes voltam para webhook/log).
# Também respeita DISABLE_WHATSAPP_BOOT=true como bypass emergencial.
ENABLE_WHATSAPP=true
DISABLE_WHATSAPP_BOOT=false

# Redis — necessário para BullMQ (queue de mensagens)
# Em desenvolvimento local: redis://localhost:6379
# Em docker-compose: redis://redis:6379
REDIS_URL=redis://localhost:6379

# Número do admin para receber notificações de handoff da IA
# Formato: 5511999990000 (com DDI, sem + ou espaços)
# ADMIN_WHATSAPP_NUMBER=5511999990000

# Tempo (em minutos) para reativar IA após intervenção humana (padrão: 60)
SARAH_AUTO_REENABLE_MINUTES=60

# Tempo (em minutos) sem mensagem para considerar socket "zumbi" e reconectar (padrão: 10)
SARAH_ZOMBIE_TIMEOUT_MINUTES=10

# ──────────────────────────────────────────────
#  Integração Pix
# ──────────────────────────────────────────────
# "mock" (padrão dev) ou "efibank" (produção)
PIX_PROVIDER=mock

# Credenciais Efí Bank (obrigatórias apenas quando PIX_PROVIDER=efibank)
# EFI_CLIENT_ID=
# EFI_CLIENT_SECRET=
# EFI_PIX_KEY=sua_chave_pix_evp_ou_cpf_ou_email
# EFI_SANDBOX=true

# ──────────────────────────────────────────────
#  Google Calendar (OAuth2)
# ──────────────────────────────────────────────
# Crie em: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Redirect URI autorizado: http://localhost:3000/auth/google/callback (dev)
#                          https://seudominio.com/auth/google/callback (prod)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_CALENDAR_NAME=Sessões_Terapia

# Fuso horário dos eventos criados no Google Calendar
TZ_CALENDAR=America/Sao_Paulo
