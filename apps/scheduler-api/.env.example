# Porta da aplicação
PORT=3000

# Conexão com o Banco de Dados (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/whatsapp_scheduler"

# Conexão com o Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Ambiente de Execução (development, production)
NODE_ENV=development

# Configuração de Segurança de Rotas
# Se 'true', permite o fallback para 'default-user-id' se x-user-id estiver ausente em desenvolvimento
ALLOW_DEFAULT_USER=true
DEFAULT_USER_ID=default-user-id

# Token do Bot do Telegram (Opcional)
TELEGRAM_BOT_TOKEN=

# API Key do Google Gemini AI
GEMINI_API_KEY=
# Modelo do Gemini para a Secretária (Opcional, padrão: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Número de WhatsApp do Administrador para receber relatórios
ADMIN_WHATSAPP_NUMBER=

# Google Calendar OAuth API Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
